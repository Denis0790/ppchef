# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_DB=ppchef
POSTGRES_USER=ppchef_user
POSTGRES_PASSWORD=пароль
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ─── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=пароль
REDIS_HOST=redis
REDIS_PORT=6379

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET_KEY=жвт
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=14

# ─── FastAPI ──────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
CORS_ORIGINS=http://localhost:3000

# ─── Timeweb S3 ───────────────────────────────────────────────
S3_ENDPOINT_URL=https://s3.timeweb.cloud
S3_ACCESS_KEY=ключ
S3_SECRET_KEY=ключ
S3_BUCKET_NAME=ppchef-media
S3_REGION=ru-1
S3_PUBLIC_URL=https://ppchef-media.s3.timeweb.cloud

# ─── Celery ───────────────────────────────────────────────────
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# ─── Flower ───────────────────────────────────────────────────
FLOWER_USER=
FLOWER_PASSWORD=

# ─── Email (Resend) ───────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=support@ppchef.ru
EMAIL_FROM_NAME=ПП Шеф

# ─── ЮКасса ──────────────────────────────────────────────────
YUKASSA_SHOP_ID=
YUKASSA_SECRET_KEY=

# ─── Т-Банк ──────────────────────────────────────────────────
TBANK_TERMINAL_KEY=
TBANK_SECRET_KEY=

# ─── Spoonacular ──────────────────────────────────────────────
SPOONACULAR_API_KEY=

# ─── Sentry ───────────────────────────────────────────────────
SENTRY_DSN=

OPENROUTER_API_KEY=
